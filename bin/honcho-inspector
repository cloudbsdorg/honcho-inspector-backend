#!/usr/bin/env bash
#
# honcho-inspector launcher script (POSIX: Linux, FreeBSD, macOS)
#
# This script is the dev-mode launcher. For a system install (runs as
# www-data / www / _www, with a service file and env-injection), use:
#
#   sudo bin/install-honcho-inspector
#
# The install script copies this jar to /usr/local/lib/honcho-inspector/,
# installs the per-OS service file (systemd / rc.d / launchd), and
# sets up a dedicated unprivileged service user. See the man page
# honcho-inspector(1) §INSTALLATION for the full procedure.
#
# This script resolves the OS-appropriate config dir and execs the
# honcho-inspector-backend jar with --spring.config.additional-location
# so the operator can drop a custom application.yml at the OS-appropriate
# place.
#
# Per-OS config culture (the lesson):
#   Linux:     /etc/honcho-inspector/application.yml
#   FreeBSD:   /usr/local/etc/honcho-inspector/application.yml
#   macOS:     ~/Library/Application Support/honcho-inspector/application.yml
#   Windows:   use bin/honcho-inspector.cmd (not this script)
#
# Override the config dir at any time:
#   HONCHO_CONFIG_DIR=/somewhere/else bin/honcho-inspector
#
# Override other settings via standard Spring Boot env vars:
#   PORT=9090 \
#   CORS_ALLOWED_ORIGINS=https://honcho.example.com \
#   HONCHO_BASE_URL=https://mcp.honcho.cloudbsd.org \
#   bin/honcho-inspector
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Subcommand dispatch. We only intercept the launcher's own help here.
# The Java-side CliRunner handles list-users, reset-admin-password,
# promote-to-admin, revoke-all-sessions, and help; those args are
# passed through to the jar by the java exec at the bottom of the file.
case "${1:-}" in
    --help|-h)
        cat <<'USAGE' >&2
honcho-inspector - Spring Boot launcher for the Honcho Inspector backend

Usage:
  honcho-inspector                                Start the backend (default)
  honcho-inspector --help                         Show this help
  honcho-inspector help                           Emergency CLI usage
  honcho-inspector list-users                     Emergency CLI: list every user
  honcho-inspector reset-admin-password [flags]   Emergency CLI: reset a user's password
  honcho-inspector promote-to-admin [flags]       Emergency CLI: promote a user to admin
  honcho-inspector revoke-all-sessions            Emergency CLI: wipe all auth sessions

The launcher detects the OS (Linux, FreeBSD, macOS) and resolves the
config dir, then execs java on the bundled jar. For a system install
(runs as www-data / www / _www, with a service file), use the
install script:

  sudo bin/install-honcho-inspector

First-run configuration is UI-driven: GET /api/health returns
`first_run: true` when the database is empty; the UI then calls
POST /api/setup/first-admin to create the initial admin. See the
man page honcho-inspector(1) and docs/SECURITY.md.
USAGE
        exit 0
        ;;
esac

# Probe the jar in this order:
#   1. $HONCHO_JAR_DIR (operator override)
#   2. $HOMEBREW_PREFIX/opt/honcho-inspector/libexec (Homebrew tap)
#   3. /usr/local/lib/honcho-inspector (manual POSIX install)
#   4. $PROJECT_DIR/target (dev mode)
JAR_DIR="${HONCHO_JAR_DIR:-}"
if [ -z "$JAR_DIR" ] && [ -n "${HOMEBREW_PREFIX:-}" ] \
    && [ -d "${HOMEBREW_PREFIX}/opt/honcho-inspector/libexec" ]; then
    JAR_DIR="${HOMEBREW_PREFIX}/opt/honcho-inspector/libexec"
fi
if [ -z "$JAR_DIR" ] && [ -d /usr/local/lib/honcho-inspector ]; then
    JAR_DIR=/usr/local/lib/honcho-inspector
fi
if [ -z "$JAR_DIR" ]; then
    JAR_DIR="$PROJECT_DIR/target"
fi

JAR_FILE="$(ls -1 "$JAR_DIR"/honcho-inspector-backend-*.jar 2>/dev/null | grep -v '\.original$' | head -n1 || true)"

if [ -z "${JAR_FILE:-}" ]; then
    echo "honcho-inspector: no honcho-inspector-backend-*.jar found in $JAR_DIR" >&2
    echo "  build it first with: mvn -B -ntp package" >&2
    exit 1
fi

resolve_config_dir() {
    if [ -n "${HONCHO_CONFIG_DIR:-}" ]; then
        echo "${HONCHO_CONFIG_DIR}"
        return
    fi
    local os
    os="$(uname -s 2>/dev/null || echo unknown)"
    case "$os" in
        Linux)
            echo "/etc/honcho-inspector"
            ;;
        FreeBSD|OpenBSD|NetBSD|DragonFly)
            echo "/usr/local/etc/honcho-inspector"
            ;;
        Darwin)
            local home="${HOME:-}"
            if [ -z "$home" ]; then
                echo "./"
                return
            fi
            echo "$home/Library/Application Support/honcho-inspector"
            ;;
        *)
            echo "./"
            ;;
    esac
}

# Source the per-OS env file so the jar sees HONCHO_CONFIG_DIR,
# HONCHO_DB_PATH, HONCHO_CRYPTO_KEY, and JAVA_HOME. Without this,
# an operator running `honcho-inspector list-users` from a shell
# would hit a CWD-relative empty database (because the default
# application.yml:19 has a nested fallback to HONCHO_DB_FILE resolved
# against the working directory). The env file is what the system
# service uses (systemd's EnvironmentFile=, rc.d's . $env_file, or
# the FreeBSD port's $ETCDIR/honcho-inspector.env), so sourcing it
# here puts the launcher's process on the same footing as the
# long-running service.
#
# Existing operator-set vars WIN. The `set -a` only exports new
# keys; already-set values are not overwritten. Missing files are
# silent so dev runs (no install) still work.
source_env_file() {
    local os
    os="$(uname -s 2>/dev/null || echo unknown)"
    local env_file=""
    case "$os" in
        Linux)
            for f in /etc/default/honcho-inspector /etc/sysconfig/honcho-inspector; do
                if [ -f "$f" ]; then env_file="$f"; break; fi
            done
            ;;
        FreeBSD|OpenBSD|NetBSD|DragonFly)
            for f in /etc/default/honcho-inspector \
                     "${HOMEBREW_PREFIX:-/usr/local}/etc/honcho-inspector/honcho-inspector.env"; do
                if [ -f "$f" ]; then env_file="$f"; break; fi
            done
            ;;
        Darwin)
            for f in /etc/defaults/honcho-inspector \
                     "${HOME:-}/Library/Application Support/honcho-inspector/env"; do
                if [ -f "$f" ]; then env_file="$f"; break; fi
            done
            ;;
    esac
    if [ -n "$env_file" ]; then
        set -a
        . "$env_file" 2>/dev/null || true
        set +a
    fi
}

source_env_file

CONFIG_DIR="$(resolve_config_dir)"
CONFIG_DIR_STATUS="exists"

# Mirror HonchoConfigDirResolver.resolveOrCreate(): try the OS default first,
# and on permission failure fall back to the XDG user dir. We do NOT fall back
# when running as root -- a root-level permission denied is a real config
# error and should fail loud, not silently relocate state.
if [ ! -d "$CONFIG_DIR" ]; then
    if ! mkdir -p "$CONFIG_DIR" 2>/dev/null; then
        if [ "$(id -u)" -eq 0 ]; then
            echo "honcho-inspector: config dir primary path is not writable by root: $CONFIG_DIR" >&2
            echo "  (root hitting permission denied is a real config error, not a fallback case)" >&2
            exit 1
        fi
        XDG_FALLBACK="${HOME:-.}/.local/etc/honcho-inspector"
        echo "honcho-inspector: config dir primary path not writable ($CONFIG_DIR), falling back to $XDG_FALLBACK" >&2
        if ! mkdir -p "$XDG_FALLBACK" 2>/dev/null; then
            echo "honcho-inspector: config dir primary path ($CONFIG_DIR) is not writable" >&2
            echo "  and the XDG user fallback ($XDG_FALLBACK) also failed" >&2
            exit 1
        fi
        CONFIG_DIR="$XDG_FALLBACK"
        CONFIG_DIR_STATUS="fallback"
    else
        CONFIG_DIR_STATUS="created"
    fi
fi

JAVA_OPTS="${JAVA_OPTS:-} -Xms64m -Xmx256m"
# Spring Boot properties are passed as JVM system properties (-D form), not
# as `--key=value`. Java 9+ rejects `--key=value` in the JVM-args slot; the
# `--` form is only valid as a Spring program argument (after -jar).
SPRING_OPTS=(
    "-Dspring.config.additional-location=file:${CONFIG_DIR}/"
    "-Dlogging.file.name=${HONCHO_LOG_DIR:-${CONFIG_DIR}}/honcho-inspector-backend.log"
)

echo "honcho-inspector: starting with jar=$JAR_FILE config-dir=$CONFIG_DIR [$CONFIG_DIR_STATUS]" >&2
exec java $JAVA_OPTS \
    -Dspring.profiles.active="${SPRING_PROFILES_ACTIVE:-prod}" \
    "${SPRING_OPTS[@]}" \
    -jar "$JAR_FILE" \
    "$@"
