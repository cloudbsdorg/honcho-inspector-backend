#!/usr/bin/env bash
#
# honcho-inspector launcher script (POSIX: Linux, FreeBSD, macOS)
#
# Resolves the OS-appropriate config dir and execs the honcho-inspector-backend jar
# with `--spring.config.additional-location=<dir>` so the operator can drop
# a custom application.yml at the OS-appropriate place.
#
# Per-OS config culture (the lesson):
#   Linux:     /etc/honcho-inspector/application.yml
#   FreeBSD:   /usr/local/etc/honcho-inspector/application.yml
#   macOS:     ~/Library/Application Support/honcho-inspector/application.yml
#   Windows:   use bin/honcho-inspector.cmd (not this script)
#
# Override the config dir at any time:
#   HONCHO_CONFIG_DIR=/somewhere/else bin/honcho-inspector
#
# Override other settings via standard Spring Boot env vars:
#   PORT=9090 \
#   CORS_ALLOWED_ORIGINS=https://honcho.example.com \
#   HONCHO_BASE_URL=https://mcp.honcho.cloudbsd.org \
#   bin/honcho-inspector
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

JAR_DIR="${HONCHO_JAR_DIR:-$PROJECT_DIR/target}"
JAR_FILE="$(ls -1 "$JAR_DIR"/honcho-inspector-backend-*.jar 2>/dev/null | grep -v '\.original$' | head -n1 || true)"

if [ -z "${JAR_FILE:-}" ]; then
    echo "honcho-inspector: no honcho-inspector-backend-*.jar found in $JAR_DIR" >&2
    echo "  build it first with: mvn -B -ntp package" >&2
    exit 1
fi

resolve_config_dir() {
    if [ -n "${HONCHO_CONFIG_DIR:-}" ]; then
        echo "${HONCHO_CONFIG_DIR}"
        return
    fi
    local os
    os="$(uname -s 2>/dev/null || echo unknown)"
    case "$os" in
        Linux)
            echo "/etc/honcho-inspector"
            ;;
        FreeBSD|OpenBSD|NetBSD|DragonFly)
            echo "/usr/local/etc/honcho-inspector"
            ;;
        Darwin)
            local home="${HOME:-}"
            if [ -z "$home" ]; then
                echo "./"
                return
            fi
            echo "$home/Library/Application Support/honcho-inspector"
            ;;
        *)
            echo "./"
            ;;
    esac
}

CONFIG_DIR="$(resolve_config_dir)"
mkdir -p "$CONFIG_DIR"

JAVA_OPTS="${JAVA_OPTS:-} -Xms64m -Xmx256m"
SPRING_OPTS=(
    "--spring.config.additional-location=file:${CONFIG_DIR}/"
    "--logging.file.name=${HONCHO_LOG_DIR:-${CONFIG_DIR}}/honcho-inspector-backend.log"
)

echo "honcho-inspector: starting with jar=$JAR_FILE config-dir=$CONFIG_DIR" >&2
exec java $JAVA_OPTS \
    -Dspring.profiles.active="${SPRING_PROFILES_ACTIVE:-prod}" \
    "${SPRING_OPTS[@]}" \
    -jar "$JAR_FILE" \
    "$@"
