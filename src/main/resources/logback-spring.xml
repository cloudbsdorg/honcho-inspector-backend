<?xml version="1.0" encoding="UTF-8"?>
<!--
    honcho-inspector-backend structured (JSONL) logging policy.

    Every log line is a single JSON object on its own line (JSONL / NDJSON).
    This file is loaded as `classpath:logback-spring.xml` (see application.yml)
    so Spring property placeholders and the Spring profile selector (`<springProfile>`)
    are honoured.

    Two appenders:
      FILE_JSONL  — RollingFileAppender with LogstashEncoder, JSONL on disk
      CONSOLE_JSONL — ConsoleAppender with LogstashEncoder, JSONL to stdout (for container
                      capture / `kubectl logs` / `docker logs` ingestion)
    Both share the masking rule below so any sensitive substring (`apiKey=`, `Bearer `,
    `password=`) is rewritten to `***` before the bytes leave the encoder.

    Rotation: daily AND size-triggered via `SizeAndTimeBasedRollingPolicy`; rotated
    files are compressed with gzip (suffix `.jsonl.gz`).

    The default `service` and `version` fields are injected as `<customFields>` on
    the encoder so they are present in every event without per-call boilerplate.
    MDC fields (`request_id`, `user_id`, `session_id`, `profile_id`, `honcho_version`,
    `peer_id`) are emitted automatically when set by `SessionAuthFilter` /
    `HonchoProxyService` and cleared in `finally` blocks to prevent leakage
    between requests.
-->
<configuration>

    <!--
        Resolve the log directory. Order of precedence:
          1. HONCHO_CONFIG_DIR environment variable (or system property)
          2. Current working directory (`.`)

        Operators set HONCHO_CONFIG_DIR to e.g. `/etc/honcho-inspector` and the
        `logs/` subdirectory is created automatically by RollingFileAppender.
    -->
    <property name="LOG_DIR" value="${HONCHO_CONFIG_DIR:-.}"/>

    <!--
        Project version is injected from the Maven build (see
        <resources><filtering>true</filtering></resources> if/when added; for now we
        hard-code the value to match pom.xml. The application.yml keeps the same
        constant in `honcho.log.*` so the two stay in lockstep.
    -->
    <property name="PROJECT_VERSION" value="0.1.0-SNAPSHOT"/>

    <!--
        === JSONL FILE APPENDER ===
        Rolling JSONL file with size+time based rotation. Active in every profile
        where `honcho-inspector` writes logs.
    -->
    <appender name="FILE_JSONL" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/logs/honcho-inspector.jsonl</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- rotated files are gzipped; the .jsonl suffix is preserved before .gz -->
            <fileNamePattern>${LOG_DIR}/logs/honcho-inspector.%d{yyyy-MM-dd}.%i.jsonl.gz</fileNamePattern>
            <!-- roll when the active file crosses this size; "%i" disambiguates same-day rolls -->
            <maxFileSize>${HONCHO_LOG_MAX_FILE_SIZE:-100MB}</maxFileSize>
            <!-- keep at most N days of rotated files -->
            <maxHistory>${HONCHO_LOG_MAX_HISTORY:-30}</maxHistory>
            <!-- total cap across ALL rotated + active files -->
            <totalSizeCap>${HONCHO_LOG_TOTAL_SIZE_CAP:-500MB}</totalSizeCap>
            <!-- gzip the rotated files (default for SizeAndTimeBasedRollingPolicy is .gz anyway) -->
            <compressionMode>gz</compressionMode>
        </rollingPolicy>

        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!--
                Inject constant fields into every event. The LogstashEncoder will include
                MDC fields when present (default behaviour; see includeMdc=true below).
            -->
            <customFields>{"service":"honcho-inspector-backend","version":"${PROJECT_VERSION}"}</customFields>
            <includeMdc>true</includeMdc>
            <includeContext>false</includeContext>
            <includeKeyValuePairs>false</includeKeyValuePairs>
            <includeStructuredArguments>true</includeStructuredArguments>
            <includeNonStructuredArguments>false</includeNonStructuredArguments>

            <!--
                ISO-8601 UTC timestamps ("@timestamp" field) — the field name "@timestamp"
                is set by default; the pattern below uses millisecond precision and
                an explicit "Z" suffix for UTC.
            -->
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
            <timeZone>UTC</timeZone>

            <!--
                === SECRET MASKING ===
                `MaskingJsonGeneratorDecorator` rewrites the JSON values right before
                they are written, so any string that contains one of the regexes below
                will have the captured/whole match replaced with `***` (or the
                configured replacement).

                This is the modern replacement for the old `MaskingJsonProviderDecorator`
                class (removed in 8.0). The decorator works at the Jackson level so it
                catches secrets embedded in any field — message, stack trace, MDC — not
                just a fixed field name.
            -->
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator">
                <defaultMask>***</defaultMask>
                <!--
                    <valueMask> applies a regex to every string value emitted by the
                    encoder. The first capturing group (or whole match) is replaced
                    with <mask>. Order: Bearer token (longest match first to catch
                    JWT-like dots), apiKey/api_key with quoted or unquoted value,
                    password/pass with quoted or unquoted value.

                    Each pattern is anchored loosely to also catch JSON-quoted forms
                    (e.g. `"apiKey":"secret-123"`) so a leak via JSON log content is
                    also scrubbed.
                -->
                <valueMask>
                    <value><![CDATA[(?i)(Bearer\s+)[A-Za-z0-9._\-]+]]></value>
                    <mask><![CDATA[$1***]]></mask>
                </valueMask>
                <valueMask>
                    <value><![CDATA[(?i)("?api_?key"?\s*[:=]\s*"?)([^"\s,]+)]]></value>
                    <mask><![CDATA[$1***]]></mask>
                </valueMask>
                <valueMask>
                    <value><![CDATA[(?i)("?password"?\s*[:=]\s*"?)([^"\s,]+)]]></value>
                    <mask><![CDATA[$1***]]></mask>
                </valueMask>
                <valueMask>
                    <value><![CDATA[(?i)("?pass"?\s*[:=]\s*"?)([^"\s,]+)]]></value>
                    <mask><![CDATA[$1***]]></mask>
                </valueMask>
            </jsonGeneratorDecorator>
        </encoder>
    </appender>

    <!--
        === JSONL CONSOLE APPENDER ===
        Containerized deployments capture stdout; emitting JSONL there too keeps
        ingestion consistent (one parser, one schema). Operators can pipe through
        `jq` to get readable output.
    -->
    <appender name="CONSOLE_JSONL" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"honcho-inspector-backend","version":"${PROJECT_VERSION}"}</customFields>
            <includeMdc>true</includeMdc>
            <includeContext>false</includeContext>
            <includeStructuredArguments>true</includeStructuredArguments>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
            <timeZone>UTC</timeZone>
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator">
                <defaultMask>***</defaultMask>
                <valueMask>
                    <value><![CDATA[(?i)(Bearer\s+)[A-Za-z0-9._\-]+]]></value>
                    <mask><![CDATA[$1***]]></mask>
                </valueMask>
                <valueMask>
                    <value><![CDATA[(?i)("?api_?key"?\s*[:=]\s*"?)([^"\s,]+)]]></value>
                    <mask><![CDATA[$1***]]></mask>
                </valueMask>
                <valueMask>
                    <value><![CDATA[(?i)("?password"?\s*[:=]\s*"?)([^"\s,]+)]]></value>
                    <mask><![CDATA[$1***]]></mask>
                </valueMask>
                <valueMask>
                    <value><![CDATA[(?i)("?pass"?\s*[:=]\s*"?)([^"\s,]+)]]></value>
                    <mask><![CDATA[$1***]]></mask>
                </valueMask>
            </jsonGeneratorDecorator>
        </encoder>
    </appender>

    <!--
        === LOGGERS ===
        Per spec:
          - root INFO
          - com.revytechinc.honchoinspector INFO (overridable via HONCHO_LOG_LEVEL)
          - org.springframework.web INFO (overridable)
          - org.hibernate.SQL WARN (never log SQL by default; noise + potential data leak)
          - net.logstash.logback WARN (don't spam its own logs)
    -->
    <root level="INFO">
        <appender-ref ref="FILE_JSONL"/>
        <appender-ref ref="CONSOLE_JSONL"/>
    </root>

    <logger name="com.revytechinc.honchoinspector" level="${HONCHO_LOG_LEVEL:-INFO}"/>
    <logger name="org.springframework.web" level="${HONCHO_LOG_LEVEL:-INFO}"/>
    <logger name="org.hibernate.SQL" level="WARN"/>
    <logger name="net.logstash.logback" level="WARN"/>

    <!--
        === DEV PROFILE ===
        Per spec: dev profile keeps the file appender (operators may still want
        JSONL on disk during local dev for `jq` workflows) and replaces the
        console appender with a more compact `pattern` view. Implementation note:
        the dev console uses a `PatternLayoutEncoder` for readability. The file
        appender is left unchanged so log shape stays consistent across profiles.
    -->
    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="FILE_JSONL"/>
            <appender-ref ref="CONSOLE_DEV"/>
        </root>
    </springProfile>

    <appender name="CONSOLE_DEV" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{30} - %msg%n</pattern>
        </encoder>
    </appender>

</configuration>
