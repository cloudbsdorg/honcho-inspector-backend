# honcho-inspector example operator config
#
# This file shows every overridable setting. Install it at the OS-appropriate
# path and uncomment / edit whatever you need to change:
#
#   Linux:     /etc/honcho-inspector/application.yml
#   FreeBSD:   /usr/local/etc/honcho-inspector/application.yml
#   macOS:     ~/Library/Application Support/honcho-inspector/application.yml
#
# Anything not set here falls back to the bundled defaults (see
# src/main/resources/application.yml in honcho-inspector-backend).
#
# --------------------------------------------------------------------------
# Production safety checklist (read docs/SECURITY.md §5 before deploying)
# --------------------------------------------------------------------------
# 1. Set HONCHO_CRYPTO_KEY in the environment, NOT in this file. Use
#    `openssl rand -base64 32` and load it from a secret manager.
# 2. The backend should bind to 127.0.0.1 only (see `server.address` below)
#    and be reachable exclusively from the reverse proxy. TLS, HSTS, and
#    security headers are the proxy's job — see docs/reverse-proxy.md.
# 3. CORS must list the *exact* public origin of the UI (https://...). No
#    wildcards; no http://localhost in prod.
# 4. Set session.ttl-minutes to a non-zero value so idle sessions expire.
# 5. On a fresh deploy, decide whether to use the bootstrap admin below
#    (honcho.bootstrap.*) or create the first admin by running the bundled
#    jar once, authenticating as the bootstrap user, and then using
#    POST /api/admin/users to mint the real first admin. Remove the
#    bootstrap credentials from this file once that user exists — leaving
#    them in is a credential-on-disk leak. See docs/SECURITY.md §6.
# 6. File ownership after install (set by the package manager or
#    `bin/install-honcho-inspector`):
#
#      Linux:    /etc/honcho-inspector/                       root:www-data  0750
#                /var/lib/honcho-inspector/ (sqlite db)        www-data:www-data 0750
#                /var/log/honcho-inspector/  (jsonl log)       www-data:www-data 0750
#                /etc/default/honcho-inspector  (HONCHO_CRYPTO_KEY env)  root:www-data 0640
#
#      FreeBSD:  /usr/local/etc/honcho-inspector/             root:www       0750
#                /var/db/honcho-inspector/                     www:www        0750
#                /var/log/honcho-inspector/                    www:www        0750
#                /etc/default/honcho-inspector                 root:www       0640
#
#      macOS:    /usr/local/etc/honcho-inspector/             root:_www      0750
#                /var/lib/honcho-inspector/                    _www:_www      0750
#                /var/log/honcho-inspector/                    _www:_www      0750
#                /etc/defaults/honcho-inspector                root:_www      0640
#
#    Do NOT loosen these modes to "fix" a permissions error — the error
#    is a configuration problem (the service user is wrong, the group
#    is missing, or the user is not the owner of the dir).

server:
  # port: 8080
  # Bind to loopback only — the reverse proxy is the public listener.
  # Without this, the backend is reachable on the host's external IPs.
  address: 127.0.0.1
  # Trim what Spring's error envelope leaks. The default is
  # `include-message: always` (set in the bundled yaml for dev clarity);
  # in prod, prefer `never` so unmapped exceptions don't echo upstream
  # error text to the browser. Valid Spring Boot 3.5 values are
  # ALWAYS, NEVER, ON_PARAM. (We previously suggested `when_authorized`
  # which is not a valid Spring Boot 3.5 enum value and causes
  # ApplicationContext startup failure.)
  error:
    include-message: never
    include-binding-errors: never
    include-stacktrace: never
    include-exception: false

# CORS — comma-separated list of allowed origins. Must include the URL the
# browser will use to reach the honcho-inspector UI in production. When
# the UI is served from the same origin as the API (recommended — see
# docs/reverse-proxy.md §2.4), CORS is irrelevant for that path; this
# list is defence-in-depth.
cors:
  # allowed-origins: "https://honcho.example.com"

# Honcho upstream. The user also enters this in the login form per session;
# this default is used for the startup banner and any default-fallback calls.
honcho:
  # base-url: "https://mcp.honcho.cloudbsd.org"
  # Honcho API version (default if profile.api_version is null). Supported: v3.
  api-version: v3
  # request-timeout-ms: 30000
  # Provider strict-mode (default false). When true, the server fails to start if any registered
  # HonchoProvider claims a version that has no HonchoClient implementation. Set true in prod
  # to prevent forward-incompatible deploys.
  providers:
    strict-mode: false
  # Per-profile api_version override: edit a profile row in the honcho_profiles table
  # (column api_version TEXT). NULL inherits honcho.api-version above. This is how two
  # profiles can talk to different Honcho versions simultaneously. See docs/honcho-providers.md.

  # ---- First-startup bootstrap admin --------------------------------------
  # When the users table is empty AND both admin-username AND admin-password
  # are set, AdminBootstrap (an ApplicationReadyEvent listener) creates a
  # single admin user with isAdmin=true. The bundled application.yml ships
  # this block blank; the jar cannot accidentally create an admin. The
  # operator opts in by populating this section on a fresh deploy.
  #
  # The corresponding AuditLog entry is action='user.bootstrap' with
  # actor_user_id=NULL (the bootstrap runs without a session).
  #
  # After the first admin exists, REMOVE these credentials from this file
  # and rotate the password via POST /api/admin/users/{id}/password. Leaving
  # them in is a credential-on-disk leak.
  # bootstrap:
  #   admin-username: honcho-admin
  #   admin-password: "set-via-secret-manager-not-here"
  #   admin-firstname: Honcho
  #   admin-lastname: Admin
  #   admin-email: admin@example.com
  #
  # ---- Audit log retention ------------------------------------------------
  # AuditLogDao entries are purged by age OR by table size, whichever fires
  # first. The retention job runs daily at purge-cron (default 03:00 local).
  # The job records its own audit.purge entry with the deleted counts.
  # Manual triggers: POST /api/admin/maintenance/audit/purge.
  # audit:
  #   retention-days: 90       # delete rows older than this
  #   max-rows: 1000000        # cap total row count; oldest are deleted
  #   purge-cron: "0 0 3 * * *"  # 3:00 AM local, every day

# Session config. ttl-minutes=0 means sessions never expire. In prod,
# set this to a real value (e.g. 60) so abandoned sessions are
# reaped. The `last_seen_at` index on `auth_sessions` makes this O(1).
session:
  # ttl-minutes: 60

logging:
  level:
    com.revytechinc.honchoinspector: INFO
    # org.springframework.web: INFO   # uncomment to see per-request access lines

# --------------------------------------------------------------------------
# Honcho provider architecture (HonchoClient + HonchoProvider registry,
# api_version negotiation, strict-mode failfast):
#   docs/honcho-providers.md
# --------------------------------------------------------------------------
