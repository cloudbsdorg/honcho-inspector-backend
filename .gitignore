target/
.playwright-mcp/
login-page.png
*.class
*.jar
*.log
.DS_Store
/opencode-session.txt

# Debian package build artifacts
/debian/stage/
/dist/

# fpm scratch
/tmp/fpm-*/

# Workspace-local SQLite DBs (dev mode). The live config at
# /etc/honcho-inspector/honcho-inspector.db is on the operator's
# machine, not in the repo; this is the workspace's accidental
# dev-mode DB plus its rotated journal/wal/shm sidecars and any
# .stale-* rename.
*.db
*.db-journal
*.db-wal
*.db-shm
*.db.stale-*

# Workspace-local state dirs created by the IntelliJ run configs in
# .run/ (the dev Spring Boot config writes its HONCHO_CONFIG_DIR here
# so each checkout has its own SQLite DB / logs / drop-in yaml without
# touching /etc/...). Wipe with `git clean -xdf .run-data*` to reset.
.run-data/
.run-data-*/

# Workspace-local dot-dirs that mirror runtime paths inside the
# Containerfile (see packaging/container/Containerfile). Each
# checkout gets its own dev state without touching /etc/ or
# /var/log/ on the host:
#   .etc/       mirrors /etc/honcho-inspector/        (configs, drop-in yaml)
#   .var-log/   mirrors /var/log/honcho-inspector/    (JSONL log + rotated)
# Wipe with `git clean -xdf .etc .var-log*` to reset.
.etc/
.var-log/
.var-log-*/

# Dev-time env overrides (Docker Compose convention). `.env` and
# `.env.local` / `.env.production` are local-only secrets/overrides;
# `.env.example` is the typical committed template, whitelisted below.
.env
.env.*
!.env.example
/.omo/

# Validation sandbox. Mirrors the OS layout (etc/ + var/lib + var/log)
# inside the repo so live tests of UI/backend behavior run against a
# project-local HONCHO_CONFIG_DIR + HONCHO_DB without touching the
# operator's /etc/honcho-inspector/ or /var/lib/honcho-inspector/.
# Wipe with `git clean -xdf .validation-test` to reset.
.validation-test/
