#!/bin/sh
set -e

# This postinst is invoked by fpm's debhelper-style wrapper. The wrapper
# already handles "configure vs upgrade vs abort-remove" dispatch via
# the `after_install` / `after_upgrade` function scaffolding, so we
# just put our setup logic here as flat commands -- the wrapper will
# run them in the right phase.
#
# dpkg invokes this with $1=configure $2=<old-version|empty>.

# Create the service user/group if missing. Both 'install' and
# 'configure' phases can land here; both are safe to run.
if ! getent group www-data >/dev/null; then
    addgroup --system www-data
fi
if ! getent passwd www-data >/dev/null; then
    adduser --system \
        --home /var/lib/honcho-inspector \
        --no-create-home \
        --shell /usr/sbin/nologin \
        --ingroup www-data \
        --gecos "Honcho Inspector service account" \
        www-data
fi

# State, log, config directories with correct ownership and mode.
install -d -m 0750 -o www-data -g www-data /var/lib/honcho-inspector
install -d -m 0750 -o www-data -g www-data /var/log/honcho-inspector
install -d -m 0750 -o root    -g www-data /etc/honcho-inspector

# /etc/default placeholder env file (operator fills HONCHO_CRYPTO_KEY).
# Only seed on first install (configure with empty $2), not on upgrade.
if [ -z "$2" ] && [ ! -f /etc/default/honcho-inspector ]; then
    cat > /etc/default/honcho-inspector <<'EOF'
# Honcho Inspector backend environment file.
# Secrets (HONCHO_CRYPTO_KEY, optional bootstrap credentials) belong here.
# Generate HONCHO_CRYPTO_KEY with:  openssl rand -base64 32
#HONCHO_CRYPTO_KEY=
EOF
    chmod 0640 /etc/default/honcho-inspector
    chown root:www-data /etc/default/honcho-inspector
fi

# Seed the application.yml drop-in ONLY if missing; the
# installer is idempotent and respects operator edits.
if [ ! -f /etc/honcho-inspector/application.yml ]; then
    install -m 0644 -o root -g www-data \
        /usr/local/share/honcho-inspector/etc/honcho-inspector/application.yml.example \
        /etc/honcho-inspector/application.yml || true
fi

# Reload systemd so the new unit file is picked up and start
# the service. fpm's wrapper also handles the systemd enable/start
# (we used to use --deb-systemd-enable) but we do it here too as
# belt-and-suspenders since the wrapper is not always invoked on
# a fresh install.
if [ -d /run/systemd/system ]; then
    systemctl daemon-reload
    systemctl enable honcho-inspector.service
    systemctl restart honcho-inspector.service || true
fi

exit 0